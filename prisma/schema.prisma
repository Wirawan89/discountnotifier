// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String?
  suburb        String
  role          String    @default("user") // "user" or "admin"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  stores        Store[]
  business      Business?
  notifications Notification[]
  preferences   UserPreference?
  accessLogs    UserAccessLog[]
  
  // NextAuth fields
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreference {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  favoriteCategories    Int[]    @default([])
  favoriteSuburbs       String[] @default([])
  notificationFrequency String   @default("daily") // daily, weekly, instant
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // discount, store, system
  read      Boolean  @default(false)
  data      Json?    // Additional data like storeId, discountId, etc.
  createdAt DateTime @default(now())
}

model Store {
  id          Int        @id @default(autoincrement())
  name        String
  url         String     @unique
  suburb      String
  city        String    @default("")
  country     String    @default("")
  contact     String?
  address     String?
  description String?
  catalogs    String[]   // Array of image URLs (jpg/png)

  // Relations
  category    Category   @relation(fields: [categoryId], references: [id])
  categoryId  Int
  owner       User       @relation(fields: [ownerId], references: [id])
  ownerId     Int
  business    Business?
  showcases   Showcase[]
  discounts   Discount[]
  background String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
}

model Discount {
  id            Int      @id @default(autoincrement())
  store         Store    @relation(fields: [storeId], references: [id])
  storeId       Int
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  percentage    Float?
  coupon        String?
  eCatalog      String[] // Array of image URLs (optional, can be used for discount-specific images)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  @@unique([storeId, title])
}

model Showcase {
  id          Int      @id @default(autoincrement())
  store       Store    @relation(fields: [storeId], references: [id])
  storeId     Int
  window      Int
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  stores Store[]
  businesses Business[]
  fetchLogs CategoryFetchLog[]
  userAccessLogs UserAccessLog[]
  tokenUsageLogs TokenUsageLog[]
  aiPerformanceLogs AiPerformanceLog[]
}

model Business {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId               Int?     @unique
  store                 Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  firstName             String
  lastName              String
  dob                   DateTime
  businessName          String
  address               String
  suburb                String
  state                 String
  country               String   @default("Australia")
  url                   String   @unique
  categoryId            Int
  category              Category @relation(fields: [categoryId], references: [id])
  promotionMessage      String   @db.VarChar(96)
  promotionStartDate    DateTime
  promotionEndDate      DateTime
  showcaseImages        String[] @default([])
  aiImageTextEnabled    Boolean  @default(false)
  aiImageTextPrompt     String?
  membershipType        String   @default("Silver")
  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([categoryId])
  @@index([membershipType, promotionEndDate])
  @@index([status, promotionStartDate, promotionEndDate])
}

model CategoryFetchLog {
  id              Int      @id @default(autoincrement())
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId      Int
  lastFetchedAt   DateTime @default(now())
  refreshPeriodDays Int    @default(3) // Default 3 days, configurable per category
  storesFetched   Int      @default(0)
  discountsFetched Int     @default(0)
  fetchStatus     String   @default("success") // success, failed, partial, fetching
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([categoryId])
}

model ApiConfiguration {
  id          Int      @id @default(autoincrement())
  provider    String   @unique // "openrouter", "gemini", "claude"
  isEnabled   Boolean  @default(true)
  apiKey      String?
  modelName   String?  // e.g., "perplexity/sonar"
  maxTokens   Int      @default(3000)
  temperature Float    @default(0.7)
  priority    Int      @default(1) // 1 = highest priority
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAccessLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  action     String   // "view_category", "view_store", "view_discount", "smart_fetch"
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model TokenUsageLog {
  id         Int      @id @default(autoincrement())
  provider   String   // "openrouter", "gemini", "claude"
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tokensUsed Int
  cost       Float?
  status     String   @default("success") // "success", "failed", "rate_limited"
  errorMessage String?
  createdAt  DateTime @default(now())
}

model AiPerformanceLog {
  id         Int      @id @default(autoincrement())
  provider   String   // "openrouter", "gemini", "claude"
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  responseTime Float  // in milliseconds
  successRate Float   // percentage (0-100)
  dataQuality Float   // percentage (0-100) - based on validation results
  storesFound Int     @default(0)
  discountsFound Int  @default(0)
  createdAt  DateTime @default(now())
}
